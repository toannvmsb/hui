# Local development database (SQLite file). Không phải secret.
# Trên Railway: đặt DATABASE_URL = file:/data/hui.db trong dashboard + gắn Volume tại /data
DATABASE_URL="file:./hui.db"

# ----- eKYC (mặc định: mô phỏng) -----
# Để dùng eKYC THẬT của FPT.AI: bỏ comment 2 dòng dưới và điền key từ https://console.fpt.ai
# EKYC_PROVIDER="fpt"
# FPT_API_KEY="dán-api-key-fpt-ở-đây"
# (tùy chọn) ngưỡng tự duyệt:
# EKYC_FACE_THRESHOLD="80"
# EKYC_LIVE_THRESHOLD="75"
